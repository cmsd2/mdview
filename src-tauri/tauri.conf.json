{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mdview",
  "version": "0.1.0",
  "identifier": "dev.mdview.app",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "mdview",
        "width": 900,
        "height": 1000,
        "minWidth": 400,
        "minHeight": 300
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' mdview: http://mdview.localhost data: blob:; media-src 'self' mdview: http://mdview.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:; connect-src 'self' mdview: http://mdview.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "A lightweight Markdown viewer",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
